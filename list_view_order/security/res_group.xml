<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_modify_list_view" model="res.groups">
        <field name="name">Modify List View</field>
    </record>

    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('list_view_order.group_modify_list_view'))]"/>
    </record>

    <record id="group_modify_list_view_all_fields" model="res.groups">
        <field name="name">Modify List View (All Fields)</field>
        <field
            name="implied_ids"
            eval="[(4, ref('list_view_order.group_modify_list_view'))]"
        />
    </record>

</odoo>
