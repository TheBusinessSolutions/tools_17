<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-name="list_view_order.ListRenderer" t-inherit="web.ListRenderer" t-inherit-mode="extension">
    <xpath expr="//Dropdown[contains(@class,'o_optional_columns_dropdown')]" position="before">
        <t t-set="_isListViewEditable" t-value="this.isListViewEditable ? this.isListViewEditable() : false" />
    </xpath>

    <xpath expr="//Dropdown" position="inside">
        <t t-if="_isListViewEditable">
            <div t-if="hasOptionalFields" class="dropdown-divider"/>
            <DropdownItem parentClosingMode="'none'" onSelected="() => this.onSelectedRearrangeListView()" class="'dropdown-item-rearrange-list'">
                <i class="fa fa-sort fa-fw me-2"/>
                <span>Rearrange List</span>
            </DropdownItem>
        </t>
    </xpath>
</t>

</templates>
